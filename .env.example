# ─────────────────────────────────────────────────────────────
# GeoTask — environment variable template
#
# Copy this file to .env.local and fill in your values:
#
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit real credentials.
# After any change here, restart: npm run dev
# ─────────────────────────────────────────────────────────────


# ─── Database ────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root).
# Created automatically on first run. Leave blank for default.
#
DATABASE_PATH=data/geotask.db


# ─── Map tile provider ───────────────────────────────────────
# By default GeoTask uses free OpenStreetMap tiles (no key needed).
# To switch to a commercial provider (e.g. MapTiler, Stadia Maps),
# replace the URL below and set the correct attribution.
#
# OpenStreetMap (default — no key required):
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors

# MapTiler example (paste your key after "key="):
# NEXT_PUBLIC_MAP_TILE_URL=https://api.maptiler.com/maps/streets/{z}/{x}/{y}.png?key=YOUR_MAPTILER_KEY
# NEXT_PUBLIC_MAP_ATTRIBUTION=© <a href="https://www.maptiler.com">MapTiler</a> © <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors

# Stadia Maps example (paste your API key after "api_key="):
# NEXT_PUBLIC_MAP_TILE_URL=https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png?api_key=YOUR_STADIA_KEY
# NEXT_PUBLIC_MAP_ATTRIBUTION=© <a href="https://stadiamaps.com">Stadia Maps</a> © <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors


# ─── Address autocomplete ────────────────────────────────────
# Language for Photon geocoding suggestions (photon.komoot.io).
# Supported values: en, de, fr, it
# NOTE: 'es' is NOT supported by Photon — it returns 400 errors.
#       Place names still appear in their local language regardless of this setting.
#
NEXT_PUBLIC_GEOCODE_LANG=en


# ─── Default map view ────────────────────────────────────────
# Where the map centers when first loaded.
# Uses Buenos Aires as default — change to your city.
#
NEXT_PUBLIC_DEFAULT_LAT=-34.603
NEXT_PUBLIC_DEFAULT_LNG=-58.381
NEXT_PUBLIC_DEFAULT_ZOOM=12
