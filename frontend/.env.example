# =========================================
# GeoTask Frontend — Environment Variables
# =========================================

# Backend API URL
VITE_API_URL=http://localhost:5000

# VAPID Public Key (mismo que en el backend)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# App URL (Netlify en producción)
VITE_APP_URL=http://localhost:5173
